# URL pública del cotizador virtual (iframe del widget + redirecciones)
NEXT_PUBLIC_COTIZADOR_URL=https://cotizadorpremium.cl

# Script del widget embebible (cotizadorWidget)
NEXT_PUBLIC_COTIZADOR_WIDGET_SCRIPT_URL=https://cotizador-widget.vercel.app/cotizador-widget.js

# Slug de entidad aliada (partner / agent)
NEXT_PUBLIC_COTIZADOR_AGENT_KEY=cotizaloantes

# premium = /cotizador?agent= | legacy = /{slug}?entidad= (cotizador.cotizaloantes.cl)
# Si no se define, se infiere desde NEXT_PUBLIC_COTIZADOR_URL
# NEXT_PUBLIC_COTIZADOR_ROUTING=premium

# Cotizador virtual — solo servidor (nunca NEXT_PUBLIC para la clave)
# En local: cotizaloAntes en :3000, cotizador-virtual en :3001
COTIZADOR_API_URL=https://cotizadorpremium.cl
COTIZADOR_PUBLIC_API_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=https://cotizaloantes.cl
